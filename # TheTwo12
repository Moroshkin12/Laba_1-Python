# TheTwo12. Даны натуральные числа n и k. Найти значение выражения: 1^k+2^k+3^k+...+n^k.
# Результат вывести в виде вещественного числа.
n = int(input("Введите n: "))
k = int(input("Введите k: "))
otv = 0
for i in range(1,n+1):
    mn = 1
    for j in range(k):
        mn *= i
    otv += mn
print("Значение выражения = ",otv)
