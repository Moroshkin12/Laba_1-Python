#TheTwo18. В натуральном числе N (N < 1000000000) цифры перенумеровали справа налево.
#Требуется определить минимальную цифру, имеющую наибольший номер, и вывести значение
#минимума, а так же порядковый номер найденной цифры

N = int(input("Введите натуральное число N (N < 1000000000): "))
Nstr = str(N)

min_x = 10
max_position = 0

for i in range(len(Nstr)):
    if int(Nstr[-(i+1)]) <= min_x:
        min_x = int(Nstr[-(i+1)])
        max_position = i+1

print("минимальное число = ", min_x)
print("порядковый номер = ", max_position)
