#While18. Дано целое число N (> 0). Используя операции деления нацело и взятия остатка
# от деления, найти количество и сумму его цифр.

N = int(input("Введите число : "))
ch = 0
sum = 0
while N > 0:
    ch += 1
    sum += (N%10)
    N = N // 10
print("колличество цифр = ", ch)
print("сумма цифр = ", sum)
